        "jsCode": "// Отримуємо всі вхідні об'єкти\nconst allData = Array.from($input.all()); \n\n// Перетворюємо їх на один текстовий список\nconst managers = allData.map(item => {\n  const m = item.json;\n  return `TelegramId: ${m.Telegram_id}, Name: ${m.Name}, Level: ${m.Level}, Specialization: ${m.Specialization}`;\n}).join('\\n');\n\n// Повертаємо один об'єкт, який містить цей список\nreturn { \n  managers_list: managers \n};"
